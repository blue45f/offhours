generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────
// User & Auth
// ─────────────────────────────────────────────────────────────

enum Role {
  USER
  HOST
  ADMIN
  SUPERADMIN
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  passwordHash   String?
  name           String
  phone          String?  @unique
  avatarUrl      String?
  role           Role     @default(USER)
  isVerified     Boolean  @default(false)
  isSuspended    Boolean  @default(false)
  suspendReason  String?
  marketingOptIn Boolean  @default(false)
  referralCode   String   @unique
  referredById   String?
  referredBy     User?    @relation("Referrer", fields: [referredById], references: [id])
  referees       User[]   @relation("Referrer")
  pointsKRW      Int      @default(0)
  trustScore     Int      @default(50)
  hostedCount    Int      @default(0)
  guestedCount   Int      @default(0)
  // 호스트 응답 지표 (최근 30일 캐시) — Airbnb/Peerspace/Tagvenue 동일 윈도우
  responseMedianMin   Int?
  responseRate24h     Float?
  responseSampleCount Int      @default(0)
  responseUpdatedAt   DateTime?
  lastLoginAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  refreshTokens   RefreshToken[]
  hostProfile     HostProfile?
  reservations    Reservation[]    @relation("GuestReservations")
  reviewsAuthored Review[]         @relation("AuthorReviews")
  reviewsAbout    Review[]         @relation("SubjectReviews")
  favorites       Favorite[]
  notifications   Notification[]
  chats           ChatMembership[]
  chatMessages    ChatMessage[]
  reportsFiled    Report[]         @relation("Reporter")
  disputesRaised  Dispute[]        @relation("DisputeRaiser")
  auditLogs       AuditLog[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  family    String
  userAgent String?
  ip        String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([family])
}

// ─────────────────────────────────────────────────────────────
// Host
// ─────────────────────────────────────────────────────────────

enum TaxType {
  INDIVIDUAL
  CORPORATE
}

enum PayoutCycle {
  D7
  D14
}

model HostProfile {
  id                 String      @id @default(cuid())
  userId             String      @unique
  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName       String
  businessNumber     String      @unique
  businessLicenseUrl String?
  taxType            TaxType     @default(INDIVIDUAL)
  bankName           String?
  bankAccount        String?
  payoutCycle        PayoutCycle @default(D7)
  isInsured          Boolean     @default(false)
  insuranceCertUrl   String?
  approvedAt         DateTime?
  approvedById       String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  venues Venue[]
}

// ─────────────────────────────────────────────────────────────
// Venue & Space
// ─────────────────────────────────────────────────────────────

enum VenueCategory {
  CAFE
  BAR
  RESTAURANT
  STUDIO
  GALLERY
  ROOFTOP
  HOUSE
  FITNESS
  DANCE
  PRACTICE
  WORKSHOP
  MEETING
  ETC
}

enum VenueStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  SUSPENDED
  REJECTED
}

model Venue {
  id            String        @id @default(cuid())
  hostId        String
  host          HostProfile   @relation(fields: [hostId], references: [id], onDelete: Cascade)
  name          String
  category      VenueCategory
  addressJibun  String
  addressRoad   String
  addressDetail String?
  lat           Float
  lng           Float
  region        String
  district      String
  description   String
  status        VenueStatus   @default(DRAFT)
  approvedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  spaces        Space[]
  businessHours BusinessHour[]
  holidays      Holiday[]

  @@index([region, district])
  @@index([category, status])
}

model BusinessHour {
  id          String @id @default(cuid())
  venueId     String
  venue       Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)
  weekday     Int
  openMinute  Int
  closeMinute Int

  @@unique([venueId, weekday])
}

enum RepeatRule {
  NONE
  WEEKLY
  MONTHLY
}

model Holiday {
  id      String     @id @default(cuid())
  venueId String
  venue   Venue      @relation(fields: [venueId], references: [id], onDelete: Cascade)
  date    DateTime
  repeat  RepeatRule @default(NONE)
  reason  String?

  @@index([venueId, date])
}

enum AlcoholPolicy {
  PROHIBITED
  BYOB
  HOST_LICENSED
  UNRESTRICTED
}

enum CateringPolicy {
  EXTERNAL_OK
  HOST_ONLY
  BYO_OK
}

enum SpaceStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  SUSPENDED
  REJECTED
}

model Space {
  id              String         @id @default(cuid())
  venueId         String
  venue           Venue          @relation(fields: [venueId], references: [id], onDelete: Cascade)
  slug            String         @unique
  title           String
  summary         String
  description     String
  capacityMin     Int            @default(1)
  capacityMax     Int
  areaM2          Int?
  basePriceKRW    Int
  cleaningFeeKRW  Int            @default(0)
  cleaningMinutes Int            @default(60)
  minHours        Int            @default(3)
  instantBook     Boolean        @default(false)
  alcoholPolicy   AlcoholPolicy
  cateringPolicy  CateringPolicy
  amenities       String[]
  /** use-case tags (PARTY/WEDDING_SMALL/CORPORATE_WORKSHOP…). 게스트의 멘탈모델 분류. */
  useCases        String[]
  rules           String         @default("")
  status          SpaceStatus    @default(DRAFT)
  viewCount       Int            @default(0)
  ratingAvg       Float          @default(0)
  ratingCount     Int            @default(0)
  approvedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  photos       SpacePhoto[]
  pricingRules PricingRule[]
  slots        Slot[]
  reservations Reservation[]
  reviews      Review[]
  favorites    Favorite[]

  @@index([status, createdAt])
  @@index([venueId])
}

model SpacePhoto {
  id       String  @id @default(cuid())
  spaceId  String
  space    Space   @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  url      String
  blurhash String?
  order    Int     @default(0)
  alt      String?

  @@index([spaceId, order])
}

model PricingRule {
  id          String @id @default(cuid())
  spaceId     String
  space       Space  @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  label       String
  multiplier  Float
  weekdayMask Int
  startMinute Int
  endMinute   Int
  priority    Int    @default(0)

  @@index([spaceId, priority])
}

// ─────────────────────────────────────────────────────────────
// Slot (영업외 자동 생성)
// ─────────────────────────────────────────────────────────────

model Slot {
  id          String       @id @default(cuid())
  spaceId     String
  space       Space        @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  startAt     DateTime
  endAt       DateTime
  priceKRW    Int
  isOpen      Boolean      @default(true)
  reservation Reservation?

  @@unique([spaceId, startAt, endAt])
  @@index([spaceId, startAt])
}

// ─────────────────────────────────────────────────────────────
// Reservation & Payment
// ─────────────────────────────────────────────────────────────

enum Purpose {
  PARTY
  WEDDING
  MEETING
  POPUP
  SHOOT
  OTHER
}

enum ReservationStatus {
  REQUESTED
  APPROVED
  PAID
  CHECKED_IN
  CHECKED_OUT
  COMPLETED
  CANCELED
  REFUNDED
}

model Reservation {
  id             String            @id @default(cuid())
  code           String            @unique
  spaceId        String
  space          Space             @relation(fields: [spaceId], references: [id])
  slotId         String?           @unique
  slot           Slot?             @relation(fields: [slotId], references: [id])
  guestId        String
  guest          User              @relation("GuestReservations", fields: [guestId], references: [id])
  startAt        DateTime
  endAt          DateTime
  headcount      Int
  purpose        Purpose
  note           String?
  status         ReservationStatus @default(REQUESTED)
  baseAmountKRW  Int
  cleaningFeeKRW Int               @default(0)
  depositKRW     Int               @default(0)
  totalKRW       Int
  feeKRW         Int
  cancelReason   String?
  checkInCode    String?
  checkedInAt    DateTime?
  checkedOutAt   DateTime?
  /** 호스트 체크아웃 체크리스트 — { restored, trash, audio, lights, lock, note?, photoUrls? } */
  checkoutChecklist Json?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  payment Payment?
  reviews Review[]
  chat    Chat?
  dispute Dispute?

  @@index([guestId, status])
  @@index([spaceId, startAt])
}

enum PaymentProvider {
  TOSS
}

enum PaymentStatus {
  READY
  AUTHORIZED
  CAPTURED
  PARTIAL_REFUNDED
  REFUNDED
  FAILED
}

model Payment {
  id            String          @id @default(cuid())
  reservationId String          @unique
  reservation   Reservation     @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  provider      PaymentProvider @default(TOSS)
  providerKey   String          @unique
  orderId       String          @unique
  method        String
  amountKRW     Int
  status        PaymentStatus   @default(READY)
  receiptUrl    String?
  rawResponse   Json?
  webhookEvents Json?
  authorizedAt  DateTime?
  capturedAt    DateTime?
  refundedAt    DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

enum SettlementStatus {
  PENDING
  SCHEDULED
  PAID
  FAILED
}

model Settlement {
  id          String           @id @default(cuid())
  hostId      String
  amountKRW   Int
  periodStart DateTime
  periodEnd   DateTime
  status      SettlementStatus @default(PENDING)
  invoiceUrl  String?
  paidAt      DateTime?
  createdAt   DateTime         @default(now())

  @@index([hostId, status])
}

// ─────────────────────────────────────────────────────────────
// Review
// ─────────────────────────────────────────────────────────────

model Review {
  id             String      @id @default(cuid())
  reservationId  String
  reservation    Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  authorId       String
  author         User        @relation("AuthorReviews", fields: [authorId], references: [id])
  subjectId      String
  subject        User        @relation("SubjectReviews", fields: [subjectId], references: [id])
  spaceId        String?
  space          Space?      @relation(fields: [spaceId], references: [id])
  rating         Int
  comment        String
  isPublished    Boolean     @default(false)
  publishedAt    DateTime?
  hostResponse   String?
  hostResponseAt DateTime?
  isHidden       Boolean     @default(false)
  createdAt      DateTime    @default(now())

  @@unique([reservationId, authorId])
  @@index([spaceId, isPublished])
}

// ─────────────────────────────────────────────────────────────
// Chat / Notification / Favorite
// ─────────────────────────────────────────────────────────────

model Chat {
  id            String       @id @default(cuid())
  reservationId String?      @unique
  reservation   Reservation? @relation(fields: [reservationId], references: [id])
  createdAt     DateTime     @default(now())

  members  ChatMembership[]
  messages ChatMessage[]
}

model ChatMembership {
  id         String    @id @default(cuid())
  chatId     String
  chat       Chat      @relation(fields: [chatId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt DateTime?
  createdAt  DateTime  @default(now())

  @@unique([chatId, userId])
}

model ChatMessage {
  id          String   @id @default(cuid())
  chatId      String
  chat        Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  senderId    String
  sender      User     @relation(fields: [senderId], references: [id])
  body        String
  attachments Json?
  createdAt   DateTime @default(now())

  @@index([chatId, createdAt])
}

enum NotificationType {
  RESERVATION_REQUESTED
  RESERVATION_APPROVED
  RESERVATION_REJECTED
  PAYMENT_COMPLETED
  REVIEW_REQUESTED
  CHAT_MESSAGE
  SYSTEM
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, readAt])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  spaceId   String
  space     Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, spaceId])
}

// ─────────────────────────────────────────────────────────────
// Report / Dispute / Audit
// ─────────────────────────────────────────────────────────────

enum ReportTarget {
  USER
  SPACE
  REVIEW
  MESSAGE
}

enum ReportReason {
  SCAM
  ABUSE
  INAPPROPRIATE
  FAKE_LISTING
  OTHER
}

enum ReportStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  DISMISSED
}

model Report {
  id          String       @id @default(cuid())
  reporterId  String
  reporter    User         @relation("Reporter", fields: [reporterId], references: [id])
  targetType  ReportTarget
  targetId    String
  reason      ReportReason
  description String
  status      ReportStatus @default(OPEN)
  resolution  String?
  createdAt   DateTime     @default(now())
  resolvedAt  DateTime?

  @@index([status, createdAt])
  @@index([targetType, targetId])
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_FAVOR_GUEST
  RESOLVED_FAVOR_HOST
  DISMISSED
}

model Dispute {
  id            String        @id @default(cuid())
  reservationId String        @unique
  reservation   Reservation   @relation(fields: [reservationId], references: [id])
  raisedById    String
  raisedBy      User          @relation("DisputeRaiser", fields: [raisedById], references: [id])
  reason        String
  description   String
  evidence      Json?
  status        DisputeStatus @default(OPEN)
  resolution    String?
  resolvedAt    DateTime?
  createdAt     DateTime      @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  actor      User     @relation(fields: [actorId], references: [id])
  action     String
  targetType String
  targetId   String
  before     Json?
  after      Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([targetType, targetId])
}
