generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────
// User & Auth
// ─────────────────────────────────────────────────────────────

enum Role {
  USER
  HOST
  ADMIN
  SUPERADMIN
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  passwordHash   String?
  // 가입·로그인 출처. 비밀번호 가입은 "password", Google(GIS) 가입은 "google".
  provider       String   @default("password")
  // Google 계정 고유 식별자(ID 토큰 payload.sub). OAuth 계정 연결·중복 가입 방지용.
  googleSub      String?  @unique
  name           String
  phone          String?  @unique
  avatarUrl      String?
  role           Role     @default(USER)
  isVerified     Boolean  @default(false)
  isSuspended    Boolean  @default(false)
  suspendReason  String?
  marketingOptIn Boolean  @default(false)
  referralCode   String   @unique
  referredById   String?
  referredBy     User?    @relation("Referrer", fields: [referredById], references: [id])
  referees       User[]   @relation("Referrer")
  pointsKRW      Int      @default(0)
  trustScore     Int      @default(50)
  hostedCount    Int      @default(0)
  guestedCount   Int      @default(0)
  // 호스트 응답 지표 (최근 30일 캐시) — Airbnb/Peerspace/Tagvenue 동일 윈도우
  responseMedianMin   Int?
  responseRate24h     Float?
  responseSampleCount Int      @default(0)
  responseUpdatedAt   DateTime?
  // 호스트 후기 답글 통계 (전체 기간 캐시) — answered / total
  reviewResponseRate     Float?
  reviewResponseCount    Int      @default(0)
  reviewSampleCount      Int      @default(0)
  reviewStatsUpdatedAt   DateTime?
  lastLoginAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  refreshTokens   RefreshToken[]
  hostProfile     HostProfile?
  corporateProfile CorporateProfile?
  reservations    Reservation[]    @relation("GuestReservations")
  reviewsAuthored Review[]         @relation("AuthorReviews")
  reviewsAbout    Review[]         @relation("SubjectReviews")
  reviewReplies   ReviewReply[]    @relation("ReviewReplies")
  favorites       Favorite[]
  collections     Collection[]
  waitlists       SpaceWaitlist[]
  notifications   Notification[]
  chats           ChatMembership[]
  chatMessages    ChatMessage[]
  reportsFiled    Report[]         @relation("Reporter")
  disputesRaised  Dispute[]        @relation("DisputeRaiser")
  auditLogs       AuditLog[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  family    String
  userAgent String?
  ip        String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([family])
}

// ─────────────────────────────────────────────────────────────
// Host
// ─────────────────────────────────────────────────────────────

enum TaxType {
  INDIVIDUAL
  CORPORATE
}

/**
 * 법인 결제 프로필 — 사내 워크샵·팀빌딩 use case 의 핵심 마찰점인 세금계산서 발행을
 * 한 번 등록해두고 예약 시 토글로 첨부. 게스트 본인 1:1 프로필이고, 그 예약은
 * 자동으로 법인 결제로 표시되어 호스트가 세금계산서 발행 의무를 인지한다.
 */
model CorporateProfile {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName     String
  businessNumber  String
  ceoName         String
  billingEmail    String
  taxOfficeAddress String?
  /** 세금계산서 발행 사업자 유형 — 일반과세자/면세사업자 */
  taxPayer         CorporateTaxType @default(GENERAL)
  /** 영업 외 크레딧 잔액 — 기업이 선충전(보너스)하고 예약에 차감하는 B2B 멤버십 */
  creditBalanceKRW Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

enum CorporateTaxType {
  GENERAL
  TAX_FREE
}

enum PayoutCycle {
  D7
  D14
}

model HostProfile {
  id                 String      @id @default(cuid())
  userId             String      @unique
  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName       String
  businessNumber     String      @unique
  businessLicenseUrl String?
  taxType            TaxType     @default(INDIVIDUAL)
  bankName           String?
  bankAccount        String?
  payoutCycle        PayoutCycle @default(D7)
  isInsured          Boolean     @default(false)
  insuranceCertUrl   String?
  approvedAt         DateTime?
  approvedById       String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  venues Venue[]
}

// ─────────────────────────────────────────────────────────────
// Venue & Space
// ─────────────────────────────────────────────────────────────

enum VenueCategory {
  CAFE
  BAR
  RESTAURANT
  STUDIO
  GALLERY
  ROOFTOP
  HOUSE
  FITNESS
  DANCE
  PRACTICE
  WORKSHOP
  MEETING
  ETC
}

enum VenueStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  SUSPENDED
  REJECTED
}

model Venue {
  id            String        @id @default(cuid())
  hostId        String
  host          HostProfile   @relation(fields: [hostId], references: [id], onDelete: Cascade)
  name          String
  category      VenueCategory
  addressJibun  String
  addressRoad   String
  addressDetail String?
  lat           Float
  lng           Float
  region        String
  district      String
  description   String
  status        VenueStatus   @default(DRAFT)
  approvedAt    DateTime?
  /** 결제 완료 게스트에게 자동 노출되는 도착 가이드(JSON) — 주차·Wi-Fi·출입·분리수거 등 */
  arrivalGuide  Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  spaces            Space[]
  businessHours     BusinessHour[]
  holidays          Holiday[]
  blocks            VenueBlock[]
  externalCalendars ExternalCalendar[]

  @@index([region, district])
  @@index([category, status])
}

model BusinessHour {
  id          String @id @default(cuid())
  venueId     String
  venue       Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)
  weekday     Int
  openMinute  Int
  closeMinute Int

  @@unique([venueId, weekday])
}

enum RepeatRule {
  NONE
  WEEKLY
  MONTHLY
}

model Holiday {
  id      String     @id @default(cuid())
  venueId String
  venue   Venue      @relation(fields: [venueId], references: [id], onDelete: Cascade)
  date    DateTime
  repeat  RepeatRule @default(NONE)
  reason  String?

  @@index([venueId, date])
}

enum BlockSource {
  MANUAL
  EXTERNAL
}

/**
 * 호스트가 슬롯 노출을 막는 시간 블록. 카톡으로 받은 외부 예약, 본인 일정, iCal 동기화된
 * 구글 캘린더 일정 등. 검색·예약 시 이 시간대와 겹치는 슬롯은 자동으로 제외돼 더블 부킹
 * 가능성을 차단한다. Airbnb/Peerspace 의 핵심 호스트 기능이지만 한국 공간대여에는 부재.
 */
model VenueBlock {
  id                  String            @id @default(cuid())
  venueId             String
  venue               Venue             @relation(fields: [venueId], references: [id], onDelete: Cascade)
  label               String
  startAt             DateTime
  endAt               DateTime
  source              BlockSource       @default(MANUAL)
  externalCalendarId  String?
  externalCalendar    ExternalCalendar? @relation(fields: [externalCalendarId], references: [id], onDelete: SetNull)
  externalUid         String?
  color               String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@unique([externalCalendarId, externalUid])
  @@index([venueId, startAt])
}

/**
 * 호스트의 외부 캘린더(iCal URL) — 구글 캘린더, 네이버 캘린더 등. 정기적으로 가져와
 * VenueBlock 으로 캐싱. 동기화 실패는 lastError 에 기록해 UI 에 노출.
 */
model ExternalCalendar {
  id            String       @id @default(cuid())
  venueId       String
  venue         Venue        @relation(fields: [venueId], references: [id], onDelete: Cascade)
  label         String
  icsUrl        String
  color         String?
  lastSyncedAt  DateTime?
  lastError     String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  blocks VenueBlock[]

  @@index([venueId])
}

enum AlcoholPolicy {
  PROHIBITED
  BYOB
  HOST_LICENSED
  UNRESTRICTED
}

enum CateringPolicy {
  EXTERNAL_OK
  HOST_ONLY
  BYO_OK
}

enum SpaceStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  SUSPENDED
  REJECTED
}

// 안심 보장 등급 — 영업 중인 가게를 통째로 빌려주는 영업 외 대관의 #1 진입장벽(파손·도난 공포)을
// 해소. 게스트가 건당 보장료를 부담하고(하이브리드 모델), 호스트는 보장 한도까지 파손을 보장받는다.
// 보장료는 보장 풀을 적립하므로 호스트 매출/수수료(12%) 대상이 아니다.
enum ProtectionTier {
  NONE
  STANDARD
  PREMIUM
}

// 취소·환불 정책 티어 — 호스트가 공간별로 선택. 영업 외 라스트미닛엔 FLEXIBLE 이 전환 레버,
// 인기 주말 공간엔 STRICT 로 노쇼 방어. 스페이스클라우드·아워플레이스의 단일 고정 정책과 차별.
enum CancellationPolicy {
  FLEXIBLE
  STANDARD
  STRICT
}

model Space {
  id              String         @id @default(cuid())
  venueId         String
  venue           Venue          @relation(fields: [venueId], references: [id], onDelete: Cascade)
  slug            String         @unique
  title           String
  summary         String
  description     String
  capacityMin     Int            @default(1)
  capacityMax     Int
  areaM2          Int?
  basePriceKRW    Int
  cleaningFeeKRW  Int            @default(0)
  /** 선택 보증금 — 결제 시 함께 예치, 분쟁 없으면 이용 완료 7일 후 자동 환급 */
  depositKRW      Int            @default(0)
  cleaningMinutes Int            @default(60)
  minHours        Int            @default(3)
  instantBook     Boolean        @default(false)
  alcoholPolicy   AlcoholPolicy
  cateringPolicy  CateringPolicy
  protectionTier  ProtectionTier @default(NONE)
  cancellationPolicy CancellationPolicy @default(STANDARD)
  amenities       String[]
  /** use-case tags (PARTY/WEDDING_SMALL/CORPORATE_WORKSHOP…). 게스트의 멘탈모델 분류. */
  useCases        String[]
  rules           String         @default("")
  status          SpaceStatus    @default(DRAFT)
  viewCount       Int            @default(0)
  ratingAvg       Float          @default(0)
  ratingCount     Int            @default(0)
  approvedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  photos       SpacePhoto[]
  pricingRules PricingRule[]
  slots        Slot[]
  reservations Reservation[]
  reviews      Review[]
  favorites    Favorite[]
  waitlist     SpaceWaitlist[]
  addons       SpaceAddon[]
  inquiryChats Chat[]

  @@index([status, createdAt])
  @@index([venueId])
}

model SpacePhoto {
  id       String  @id @default(cuid())
  spaceId  String
  space    Space   @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  url      String
  blurhash String?
  order    Int     @default(0)
  alt      String?

  @@index([spaceId, order])
}

model PricingRule {
  id          String @id @default(cuid())
  spaceId     String
  space       Space  @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  label       String
  multiplier  Float
  weekdayMask Int
  startMinute Int
  endMinute   Int
  priority    Int    @default(0)

  @@index([spaceId, priority])
}

// ─────────────────────────────────────────────────────────────
// Slot (영업외 자동 생성)
// ─────────────────────────────────────────────────────────────

model Slot {
  id          String       @id @default(cuid())
  spaceId     String
  space       Space        @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  startAt     DateTime
  endAt       DateTime
  priceKRW    Int
  isOpen      Boolean      @default(true)
  reservation Reservation?

  @@unique([spaceId, startAt, endAt])
  @@index([spaceId, startAt])
}

// ─────────────────────────────────────────────────────────────
// Reservation & Payment
// ─────────────────────────────────────────────────────────────

enum Purpose {
  PARTY
  WEDDING
  MEETING
  POPUP
  SHOOT
  OTHER
}

enum ReservationStatus {
  REQUESTED
  APPROVED
  PAID
  CHECKED_IN
  CHECKED_OUT
  COMPLETED
  CANCELED
  REFUNDED
}

enum RsvpStatus {
  GOING
  MAYBE
  NO
}

model Reservation {
  id             String            @id @default(cuid())
  code           String            @unique
  spaceId        String
  space          Space             @relation(fields: [spaceId], references: [id])
  slotId         String?           @unique
  slot           Slot?             @relation(fields: [slotId], references: [id])
  guestId        String
  guest          User              @relation("GuestReservations", fields: [guestId], references: [id])
  startAt        DateTime
  endAt          DateTime
  headcount      Int
  purpose        Purpose
  note           String?
  status         ReservationStatus @default(REQUESTED)
  baseAmountKRW  Int
  cleaningFeeKRW Int               @default(0)
  depositKRW     Int               @default(0)
  /** 보증금 자동 환급 시각 — 분쟁 없이 이용 완료 7일 경과 시 설정 */
  depositReleasedAt DateTime?
  totalKRW       Int
  feeKRW         Int
  cancelReason   String?
  checkInCode    String?
  checkedInAt    DateTime?
  checkedOutAt   DateTime?
  /** 호스트 체크아웃 체크리스트 — { restored, trash, audio, lights, lock, note?, photoUrls? } */
  checkoutChecklist Json?
  /** 법인 결제 — 예약 시점 corporate 스냅샷(공급자명·사업자번호·세금계산서 이메일) */
  corporateProfileId String?
  corporateSnapshot  Json?
  /** 법인 크레딧으로 차감한 금액 — 실 결제액 = totalKRW - creditAppliedKRW */
  creditAppliedKRW Int             @default(0)
  /** 적립 포인트로 차감한 금액 — 실 결제액에서 추가 차감 */
  pointsAppliedKRW Int             @default(0)
  /** 선택한 유료 옵션(애드온)의 합계와 스냅샷 — [{ addonId, name, unit, qty, unitPriceKRW, amountKRW }] */
  addonsAmountKRW Int             @default(0)
  addonsSnapshot  Json?
  /** 안심 보장 — 예약 시점 등급·게스트 부담 보장료(수수료 대상 아님)·보장 한도 스냅샷 */
  protectionTier        ProtectionTier @default(NONE)
  protectionFeeKRW      Int            @default(0)
  protectionCoverageKRW Int            @default(0)
  /** 취소 정책 스냅샷 — 예약 시점 공간 정책을 동결(호스트가 정책을 바꿔도 기존 예약은 보존) */
  cancellationPolicy    CancellationPolicy @default(STANDARD)
  /** 반복 예약 그룹 식별자 — 같은 정기 예약의 여러 occurrence 를 묶는 UUID */
  recurringGroupId String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  payment Payment?
  reviews Review[]
  chat    Chat?
  dispute Dispute?
  split   ReservationSplit?
  rsvps   EventRsvp[]
  cleaningJob CleaningJob?

  @@index([guestId, status])
  @@index([spaceId, startAt])
  @@index([recurringGroupId])
}

model EventRsvp {
  id            String      @id @default(cuid())
  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  name          String
  status        RsvpStatus
  clientToken   String
  createdAt     DateTime    @default(now())

  @@unique([reservationId, clientToken])
  @@index([reservationId])
}

enum PaymentProvider {
  TOSS
}

enum PaymentStatus {
  READY
  AUTHORIZED
  CAPTURED
  PARTIAL_REFUNDED
  REFUNDED
  FAILED
}

model Payment {
  id            String          @id @default(cuid())
  reservationId String          @unique
  reservation   Reservation     @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  provider      PaymentProvider @default(TOSS)
  providerKey   String          @unique
  orderId       String          @unique
  method        String
  amountKRW     Int
  status        PaymentStatus   @default(READY)
  receiptUrl    String?
  rawResponse   Json?
  webhookEvents Json?
  authorizedAt  DateTime?
  capturedAt    DateTime?
  refundedAt    DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

/**
 * 1/N 그룹 분담 결제 — 한국 모임 문화에 맞춰 친구·동료가 토스로 본인 부담분만 송금.
 * 결제자(예약자)는 본 예약을 단독으로 결제·정산하고, 정산 진척만 추적.
 * 토스 송금은 mock 처리(POC); 실 결제는 데모 후 연동.
 */
model ReservationSplit {
  id            String           @id @default(cuid())
  reservationId String           @unique
  reservation   Reservation      @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  memberCount   Int
  perMemberKRW  Int
  note          String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  members SplitMember[]

  @@index([reservationId])
}

enum SplitMemberStatus {
  PENDING
  PAID
  CANCELED
}

model SplitMember {
  id        String            @id @default(cuid())
  splitId   String
  split     ReservationSplit  @relation(fields: [splitId], references: [id], onDelete: Cascade)
  idx       Int
  /** 청구 링크에 들어가는 공개 토큰 */
  token     String            @unique @default(cuid())
  label     String?
  status    SplitMemberStatus @default(PENDING)
  paidAt    DateTime?
  createdAt DateTime          @default(now())

  @@unique([splitId, idx])
  @@index([token])
}

enum SettlementStatus {
  PENDING
  SCHEDULED
  PAID
  FAILED
}

model Settlement {
  id          String           @id @default(cuid())
  hostId      String
  amountKRW   Int
  periodStart DateTime
  periodEnd   DateTime
  status      SettlementStatus @default(PENDING)
  invoiceUrl  String?
  paidAt      DateTime?
  createdAt   DateTime         @default(now())

  @@index([hostId, status])
}

// ─────────────────────────────────────────────────────────────
// Review
// ─────────────────────────────────────────────────────────────

model Review {
  id             String      @id @default(cuid())
  reservationId  String
  reservation    Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  authorId       String
  author         User        @relation("AuthorReviews", fields: [authorId], references: [id])
  subjectId      String
  subject        User        @relation("SubjectReviews", fields: [subjectId], references: [id])
  spaceId        String?
  space          Space?      @relation(fields: [spaceId], references: [id])
  rating         Int
  comment        String
  isPublished    Boolean     @default(false)
  publishedAt    DateTime?
  hostResponse   String?
  hostResponseAt DateTime?
  isHidden       Boolean     @default(false)
  /** 이미지 첨부 — 업로드 인프라 없이 data-URL(≤1600px, ≤2MB) 배열로 인라인 저장 */
  attachments    Json?
  createdAt      DateTime    @default(now())

  replies ReviewReply[]

  @@unique([reservationId, authorId])
  @@index([spaceId, isPublished])
}

/**
 * 후기 1단 답글 스레드 — 호스트 공식 답변(hostResponse)과 별개로 후기 작성자·호스트가
 * 이어가는 평면 답글. 중첩 없이 후기 바로 아래 1단으로만 쌓인다.
 */
model ReviewReply {
  id        String   @id @default(cuid())
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation("ReviewReplies", fields: [authorId], references: [id])
  body      String
  isHidden  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([reviewId, createdAt])
}

// ─────────────────────────────────────────────────────────────
// Chat / Notification / Favorite
// ─────────────────────────────────────────────────────────────

model Chat {
  id            String       @id @default(cuid())
  reservationId String?      @unique
  reservation   Reservation? @relation(fields: [reservationId], references: [id])
  /** 예약 전 문의 쪽지 — 공간 기준 게스트↔호스트 스레드. reservationId 와 상호 배타 */
  spaceId       String?
  space         Space?       @relation(fields: [spaceId], references: [id], onDelete: SetNull)
  createdAt     DateTime     @default(now())

  members  ChatMembership[]
  messages ChatMessage[]

  @@index([spaceId])
}

model ChatMembership {
  id         String    @id @default(cuid())
  chatId     String
  chat       Chat      @relation(fields: [chatId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt DateTime?
  createdAt  DateTime  @default(now())

  @@unique([chatId, userId])
}

model ChatMessage {
  id          String   @id @default(cuid())
  chatId      String
  chat        Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  senderId    String
  sender      User     @relation(fields: [senderId], references: [id])
  body        String
  attachments Json?
  /** 신고 처리로 관리자 숨김 — 스레드 흐름 보존을 위해 삭제 대신 마스킹 */
  isHidden    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([chatId, createdAt])
}

enum NotificationType {
  RESERVATION_REQUESTED
  RESERVATION_APPROVED
  RESERVATION_REJECTED
  PAYMENT_COMPLETED
  REVIEW_REQUESTED
  CHAT_MESSAGE
  SYSTEM
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, readAt])
}

/**
 * 빈자리 알림 대기 — 인기 공간이 꽉 찼을 때 게스트가 신청. 취소·신규 슬롯 발생 시 알림.
 * 호스트에겐 "N명 대기 중" 수요 신호로 노출되어 영업 외 시간을 더 열도록 유도(= 추가 수입).
 */
model SpaceWaitlist {
  id         String    @id @default(cuid())
  spaceId    String
  space      Space     @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /** 원하는 날짜(선택). null = 아무 날이나 */
  desiredDate DateTime?
  notifiedAt DateTime?
  createdAt  DateTime  @default(now())

  @@unique([spaceId, userId])
  @@index([spaceId])
}

model Favorite {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  spaceId      String
  space        Space       @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  /** 어느 컬렉션에 담겼는지. null = 기본 "찜" 폴더 */
  collectionId String?
  collection   Collection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  /** 컬렉션 안에서의 개인 메모 (예: "친구 추천", "주차 확인 필요") */
  note         String?
  createdAt    DateTime    @default(now())

  votes CollectionItemVote[]

  @@unique([userId, spaceId])
  @@index([collectionId])
}

enum VoteValue {
  UP
  DOWN
}

/**
 * 공개 컬렉션의 후보 공간에 친구·동료가 익명 닉네임으로 남기는 1인 1표 투표.
 * voterToken 은 브라우저 localStorage 에서 발급해 (cuid) 같은 사람의 중복 투표를 막는다.
 * Pinterest Collab Board 의 공간대여 버전 — 한국 그룹 의사결정 문화 fit.
 */
model CollectionItemVote {
  id          String    @id @default(cuid())
  favoriteId  String
  favorite    Favorite  @relation(fields: [favoriteId], references: [id], onDelete: Cascade)
  voterToken  String
  voterName   String
  vote        VoteValue
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([favoriteId, voterToken])
  @@index([favoriteId])
}

/**
 * 게스트가 후보 공간을 폴더로 정리하고 친구와 공유하는 위시리스트.
 * "26살 여름 결혼식 후보 12곳", "사내 워크샵 후보" 같이 그룹 의사결정용.
 * Airbnb Wishlists 의 한국 공간대여 적용.
 */
model Collection {
  id            String     @id @default(cuid())
  ownerId       String
  owner         User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  slug          String     @unique
  name          String
  description   String?
  emoji         String?
  /** 공개 컬렉션은 슬러그 URL 로 누구나 볼 수 있음. 친구와 공유. */
  isPublic      Boolean    @default(false)
  coverPhotoUrl String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  favorites Favorite[]

  @@index([ownerId])
}

// ─────────────────────────────────────────────────────────────
// Report / Dispute / Audit
// ─────────────────────────────────────────────────────────────

enum ReportTarget {
  USER
  SPACE
  REVIEW
  MESSAGE
}

enum ReportReason {
  SCAM
  ABUSE
  INAPPROPRIATE
  FAKE_LISTING
  OTHER
}

enum ReportStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  DISMISSED
}

model Report {
  id          String       @id @default(cuid())
  reporterId  String
  reporter    User         @relation("Reporter", fields: [reporterId], references: [id])
  targetType  ReportTarget
  targetId    String
  reason      ReportReason
  description String
  status      ReportStatus @default(OPEN)
  resolution  String?
  createdAt   DateTime     @default(now())
  resolvedAt  DateTime?

  @@index([status, createdAt])
  @@index([targetType, targetId])
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_FAVOR_GUEST
  RESOLVED_FAVOR_HOST
  DISMISSED
}

// 분쟁 유형 — DAMAGE 는 안심 보장 청구(파손·도난). 체크아웃 사진이 증빙으로 자동 첨부된다.
enum DisputeKind {
  GENERAL
  DAMAGE
}

model Dispute {
  id            String        @id @default(cuid())
  reservationId String        @unique
  reservation   Reservation   @relation(fields: [reservationId], references: [id])
  raisedById    String
  raisedBy      User          @relation("DisputeRaiser", fields: [raisedById], references: [id])
  kind             DisputeKind @default(GENERAL)
  reason        String
  description   String
  evidence      Json?
  /** 청구 금액(DAMAGE) 과 예약 보장 한도 스냅샷 */
  amountClaimedKRW Int?
  coverageKRW      Int?
  status        DisputeStatus @default(OPEN)
  resolution    String?
  resolvedAt    DateTime?
  createdAt     DateTime      @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  actor      User     @relation(fields: [actorId], references: [id])
  action     String
  targetType String
  targetId   String
  before     Json?
  after      Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([targetType, targetId])
}

// ─────────────────────────────────────────────────────────────
// SpaceAddon — 호스트가 영업 외 대관에 끼워 파는 유료 옵션.
// 같은 짜투리 시간에 공간 + 장비·케이터링·세팅까지 팔아 객단가를 올린다.
// ─────────────────────────────────────────────────────────────

enum AddonUnit {
  PER_BOOKING // 건당
  PER_HOUR // 시간당
  PER_PERSON // 인당
}

enum AddonCategory {
  EQUIPMENT // 장비
  CATERING // 케이터링·음식
  SETUP // 데코·세팅
  STAFF // 인력
  CLEANING // 청소·정리
  OTHER
}

model SpaceAddon {
  id          String        @id @default(cuid())
  spaceId     String
  space       Space         @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  name        String
  description String?
  priceKRW    Int
  unit        AddonUnit     @default(PER_BOOKING)
  category    AddonCategory @default(OTHER)
  isActive    Boolean       @default(true)
  order       Int           @default(0)
  createdAt   DateTime      @default(now())

  @@index([spaceId, isActive, order])
}

// ─────────────────────────────────────────────────────────────
// 청소 대행 마켓 — 청소 SLA 의 Phase 2 완성. 청소비가 있는 예약에 지역 기반으로 제휴
// 청소업체를 자동 매칭해 "다음 영업 전 원상복구" 라는 호스트 #1 진입장벽을 운영으로 닫는다.
// 스페이스클라우드/아워플레이스/Peerspace 어디에도 없는 차별점.
// ─────────────────────────────────────────────────────────────

model CleaningPartner {
  id             String   @id @default(cuid())
  name           String
  region         String
  phone          String?
  pricePerJobKRW Int      @default(0)
  ratingAvg      Float    @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  jobs CleaningJob[]

  @@index([region, isActive])
}

enum CleaningJobStatus {
  SCHEDULED
  DONE
  CANCELED
}

model CleaningJob {
  id            String            @id @default(cuid())
  reservationId String            @unique
  reservation   Reservation       @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  partnerId     String
  partner       CleaningPartner   @relation(fields: [partnerId], references: [id])
  scheduledAt   DateTime
  status        CleaningJobStatus @default(SCHEDULED)
  feeKRW        Int               @default(0)
  createdAt     DateTime          @default(now())

  @@index([partnerId, scheduledAt])
}
