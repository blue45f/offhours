# ─────────────────────────────────────────────────────────────
# Root environment (copy to .env and fill)
# ─────────────────────────────────────────────────────────────

NODE_ENV=development

# Database
DATABASE_URL="postgresql://offhours:offhours@localhost:5432/offhours?schema=public"

# API
PORT=3000
JWT_SECRET="change-me-to-a-long-random-string-32-bytes-min"
JWT_REFRESH_SECRET="change-me-too-long-random-string-32-bytes-min"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"
APP_URL="http://localhost:5173"
API_URL="http://localhost:3000"

# Toss Payments (테스트 키)
TOSS_CLIENT_KEY="test_ck_xxxxxxxxxxxx"
TOSS_SECRET_KEY="test_sk_xxxxxxxxxxxx"
TOSS_WEBHOOK_SECRET=""

# Storage (선택)
AWS_REGION="ap-northeast-2"
AWS_S3_BUCKET=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Notification (Phase 2)
SES_FROM="no-reply@offhours.kr"
KAKAO_BIZ_KEY=""

# Web (Vite) — VITE_* 만 클라이언트로 노출
VITE_API_URL="http://localhost:3000"
VITE_TOSS_CLIENT_KEY="test_ck_xxxxxxxxxxxx"
