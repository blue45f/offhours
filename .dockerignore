# Keep the Docker build context small and free of host-only / secret files.
# The production API image is built from the repository root context
# (render.yaml dockerContext: .), so this root file is what Docker honors.

# Dependencies & build output (rebuilt inside the image)
**/node_modules
**/dist
**/build
**/coverage
**/.pnpm-store
**/*.tsbuildinfo

# Secrets & local env (image gets config via runtime env vars)
**/.env
**/.env.*
!**/.env.example

# Frontend app and docs are not part of the API image
apps/web
docs

# Local-only infra
docker-compose.yml

# VCS / tooling / editor noise
.git
.github
.husky
.idea
.vscode
.impeccable
**/.DS_Store
**/*.log

# Keep source: apps/api/src and packages/shared/src are required by the build.
# No ignore rule above touches **/src.
